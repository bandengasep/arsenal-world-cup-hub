# World Cup AI Hub — environment template. Copy to .env.local and fill with real values.
# .env.local is gitignored; this file (.env.example) is committed for judges/teammates.

MOONSHOT_API_KEY=            # Kimi K2.6 (code-gen) — Moonshot OpenAI-compatible
TOKENROUTER_API_KEY=         # TokenRouter gateway (tr_...). Add Anthropic key in Console->Providers (BYOK)
DAYTONA_API_KEY=             # Daytona sandboxed Python execution
VIDEO_DB_API_KEY=            # VideoDB highlight search
BRIGHTDATA_API_TOKEN=        # Bright Data API token
BRIGHTDATA_SERP_ZONE=        # Bright Data SERP zone name (created in Control Panel)
BRIGHTDATA_UNLOCKER_ZONE=    # Bright Data Web Unlocker zone name (created in Control Panel)
# VERCEL_TOKEN is provided via .envrc (gitignored) — used for deploys.
